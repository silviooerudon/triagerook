# TriageRook environment variables. Copy to .env.local for dev and
# set the corresponding entries on Vercel → Project → Settings →
# Environment Variables for prod.
#
# Everything above the divider is REQUIRED for the app to boot.
# Everything below is optional — set to enable specific features
# (auto-fix PRs) or to harden the deployment for a traffic spike.

# --- Required ---

# Supabase: scans, suppressions, rate-limit storage. EU region.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SECRET_KEY=service_role_key_here

# NextAuth core secret (any 32-byte random string, e.g. `openssl rand -hex 32`).
AUTH_SECRET=

# GitHub OAuth App credentials — power "Sign in with GitHub" on /signin.
# Create the OAuth App at https://github.com/settings/developers
# Callback URL: https://YOUR-DOMAIN/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# --- Optional: auto-fix PR feature ---
# Identity of the TriageRook Security GitHub App that users install on
# their repos so TriageRook can open auto-fix PRs. If unset, the rest of
# the product works; clicking "Open fix PR" just returns a clear
# "App not installed" error.
AUTH_GITHUB_APP_ID=
AUTH_GITHUB_APP_CLIENT_ID=
AUTH_GITHUB_APP_CLIENT_SECRET=
AUTH_GITHUB_APP_PRIVATE_KEY=
AUTH_GITHUB_APP_INSTALLATION_ID=

# --- Optional: launch-window levers (for Show HN, Product Hunt, etc.) ---

# Server-side GitHub PAT used by /api/scan-public when the visitor is
# anonymous. Scope MUST be `public_repo` only — leaking a wider scope
# expands the blast radius beyond what anonymous visitors already have.
#
# Without this, anonymous scans share GitHub's 60 req/hr unauthenticated
# ceiling across the whole deployment — a single front-page spike
# exhausts it in seconds. Setting this raises the effective ceiling
# to 5000 req/hr.
#
# REQUIRED before any launch that drives anonymous traffic.
PUBLIC_SCAN_GITHUB_TOKEN=

# Anonymous scan limit per source IP per hour. Default 10. Raise to
# 30–50 during a front-page event so an evaluator clicking through
# every demo repo doesn't get throttled.
PUBLIC_SCAN_LIMIT_PER_IP=

# Anonymous scan limit per `owner/repo` per hour, regardless of IP.
# Default 5. This is usually the FIRST limit a launch trips because
# every visitor tries the same demo repo. Raise to ~50 for the launch
# window; lower again afterwards.
PUBLIC_SCAN_LIMIT_PER_REPO=

# --- Optional: secret liveness validation ---
# When "true", authenticated scans additionally probe detected provider
# secrets (GitHub, GitLab, Stripe, OpenAI, Anthropic, SendGrid, Slack, npm)
# against a single read-only endpoint to mark each as live / revoked. This
# sharply cuts false-positive triage noise and boosts confirmed-live secrets
# to the top of the report.
#
# OFF by default and INTENTIONALLY never runs on the anonymous public-scan
# path — that path scans arbitrary repos, and we must not fire third-party
# API calls using strangers' leaked credentials. The raw secret value is used
# only in-memory for the probe and is never logged or stored (only the
# resulting status). Leave unset unless you understand these implications.
ENABLE_SECRET_VALIDATION=
