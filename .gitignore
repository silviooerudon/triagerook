# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code local config
.claude/


# GPG key backups (never commit private keys)
gpg-backup-*/

# Strategy / agent context docs - kept local, not tracked in public repo
# (repo is public for build-in-public branding; these docs contain
# user counts, employer info, monetization plans we keep private)
AGENTS.md
CLAUDE.md
HANDOFF.md
.agents/
docs/HANDOFF.md
docs/baseline-metrics.md
docs/handoff-*.md
docs/plan-*.md
docs/session-*.md
skills-lock.json

# Transient files used by the assistant to feed multi-line commit / PR
# bodies to gh+git on Windows (heredoc + here-string have edge cases).
# These should never be tracked.
.commit-msg.txt
.pr-body.txt
