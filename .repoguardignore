# RepoGuard suppressions
# Format: pathGlob [rule=glob] [reason="text"] [expires=YYYY-MM-DD]
# Comments start with #
#
# Each suppression scopes a (path, ruleType) pair. Suppressions are
# documented self-references where the detector matches its own
# pattern library. Real findings in the same files are NOT suppressed
# unless they belong to the explicitly scoped rule type.

# README.md describes detector capabilities. The "Private Key" wording
# in the regex pattern catalog triggers the secret detector against
# documentation describing what it detects.
README.md [rule=secret/*] [reason="Docs describe detector pattern catalog"]

# lib/secret-patterns.ts is the secret detector's regex pattern library.
# By design it contains literal text that looks like the secrets it detects.
lib/secret-patterns.ts [rule=secret/*] [reason="Detector self-reference: regex pattern library"]

# lib/code-vulns.ts is the SAST detector's rule definitions. Each rule has
# a description string that names the vuln pattern (eval, new Function,
# Math.random in security context), which the detector then matches
# against its own description.
lib/code-vulns.ts [rule=code/*] [reason="Detector self-reference: SAST rule descriptions"]

# lib/ast/rules/** holds every AST-based SAST rule. Each rule's
# `name` / `description` strings literally narrate the pattern it
# looks for ("eval() with dynamic input", "Math.random() used to
# generate a security token", "Cookie set with httpOnly: false in
# auth context"), so the regex SAST layer running over the same
# files matches the rule's own copy. Detector self-reference, same
# as lib/code-vulns.ts above. Heuristic isLikelyDetectorDefinition
# doesn't catch these because the marker is `name:`/`description:`,
# not `regex:`/`pattern:` — broadening the marker list risks false
# positives in regular code, so we suppress by path here instead.
lib/ast/rules/** [rule=code/*] [reason="Detector self-reference: AST rule name/description copy"]

# lib/biz-logic.ts is the business-logic / broken-access-control rule
# library. Each rule's `description` names the very pattern it matches
# ("`new Model(req.body)` lets the client populate every field…"), so the
# detector flags its own copy. Same self-reference dynamic as code-vulns.ts.
lib/biz-logic.ts [rule=code/*] [reason="Detector self-reference: business-logic rule descriptions"]

# lib/ai-insecure.ts is the AI-generated-insecure-code rule library. This
# layer also scans comments, so both its rule descriptions AND its module
# header (which narrates "TODO-auth markers", "in a real application…")
# match its own rules. Suppress the file's code findings by path.
lib/ai-insecure.ts [rule=code/*] [reason="Detector self-reference: AI-insecure rule descriptions + comment-scanning header"]

# scripts/patch-iam-d3-1-heredoc.py contains JavaScript embedded in a
# Python heredoc. The JS-style `dataDocRe.exec()` and `heredocRe.exec()`
# calls match the Python eval/exec rule erroneously.
scripts/patch-iam-d3-1-heredoc.py [rule=code/*] [reason="JS-in-Python-heredoc false match for Python exec()"]

# Marketing copy on the landing page enumerates the patterns the SAST
# detector flags (rejectUnauthorized: false, httpOnly: false, bcrypt
# rounds below 10, etc). The detector then matches its own FAQ text.
app/page.tsx [rule=code/*] [reason="Landing page FAQ describes SAST patterns the detector flags"]

# The security page describes how each scanner family works. Same
# self-reference dynamic as the landing page.
app/security/page.tsx [rule=code/*] [reason="Security page copy describes detector behaviour"]

# Per-rule documentation pages at /docs/rules/[ruleId] render the
# detector catalog. By construction every page contains the exact
# pattern its rule looks for.
app/docs/** [rule=code/*] [reason="Rule docs catalogue contains the patterns by design"]
app/docs/** [rule=secret/*] [reason="Rule docs catalogue contains the patterns by design"]

# scripts/test-suppressions.ts is the test fixture for this very suppression
# system. It contains intentional vuln patterns to verify suppression
# logic works end-to-end.
scripts/test-suppressions.ts [rule=code/*] [reason="Test fixture for suppression system"]

# postcss is a transitive dep via tailwindcss. Upstream Next 16 ships an
# old postcss; will resolve when Next bumps it. Time-boxed expiry forces
# us to re-evaluate.
package.json [rule=dependency/postcss] [reason="upstream next 16 ships old postcss"] [expires=2026-08-01]

# tests/code-vulns.test.ts contains intentional bad patterns as fixtures
# for the SAST detector tests. Each rule below corresponds to a fixture
# that the detector itself should match by design.
tests/code-vulns.test.ts [rule=code/js-next-public-secret-name] [reason="fixture"]
tests/code-vulns.test.ts [rule=code/js-tls-verify-disabled] [reason="fixture"]
tests/code-vulns.test.ts [rule=code/js-bcrypt-low-rounds] [reason="fixture"]
tests/code-vulns.test.ts [rule=code/js-cookie-httponly-false] [reason="fixture"]
tests/code-vulns.test.ts [rule=code/js-cookie-insecure-prod] [reason="fixture"]
tests/code-vulns.test.ts [rule=code/js-env-fallback-secret] [reason="fixture"]